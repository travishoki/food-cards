{
	"name": "food-cards-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "eslint .",
		"test": "jest",
		"ts-check": "tsc --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{js,jsx,json,css,md}": [
			"prettier --write"
		]
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"extensionsToTreatAsEsm": [
			".ts"
		],
		"moduleNameMapper": {
			"^(\\.{1,2}/.*)\\.js$": "$1"
		},
		"transform": {
			"^.+\\.tsx?$": [
				"ts-jest",
				{
					"useESM": true
				}
			]
		}
	},
	"dependencies": {
		"firebase": "^12.13.0",
		"lodash": "^4.18.1",
		"qrcode.react": "^4.2.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hot-toast": "^2.6.0",
		"react-router-dom": "6"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/jest": "29",
		"@types/lodash": "^4.17.24",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@typescript-eslint/eslint-plugin": "6",
		"@typescript-eslint/parser": "6",
		"@vitejs/plugin-react": "^4.2.1",
		"eslint": "8",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-no-only-tests": "^3.4.0",
		"eslint-plugin-perfectionist": "2",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-promise": "^7.3.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "4",
		"eslint-plugin-react-refresh": "0.4",
		"eslint-plugin-sort-destructure-keys": "^3.0.0",
		"eslint-plugin-typescript-sort-keys": "^3.3.0",
		"husky": "^9.1.7",
		"jest": "29",
		"lint-staged": "13",
		"prettier": "^3.8.3",
		"sass": "^1.99.0",
		"ts-jest": "29",
		"typescript": "~5.4.0",
		"typescript-eslint": "^8.59.3",
		"vite": "^4.5.3"
	}
}
