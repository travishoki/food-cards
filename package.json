{
  "name": "food-cards-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "29",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "6",
    "@typescript-eslint/parser": "6",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "8",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-react-hooks": "4",
    "eslint-plugin-react-refresh": "0.4",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-typescript-sort-keys": "^3.3.0",
    "jest": "29",
    "ts-jest": "29",
    "typescript": "~5.4.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^4.5.3"
  }
}
