<h1 id="top">Food Cards</h1>

<nav class="category-menu" aria-label="Food categories">
  <%= link_to "All", root_path, class: "category-menu__link#{' is-active' if @active_category.blank?}" %>
  <% @categories.each do |cat| %>
    <%= link_to cat[:label], root_path(category: cat[:key]), class: "category-menu__link#{' is-active' if @active_category == cat[:key]}" %>
  <% end %>
</nav>

<div class="food-cards">
  <% @foods_by_category.each do |group| %>
    <section id="cat-<%= group[:key] %>" class="category-section" aria-labelledby="heading-<%= group[:key] %>">
      <h2 class="category-section__title" id="heading-<%= group[:key] %>"><%= group[:label] %></h2>
      <div class="category-section__cards">
        <% group[:foods].each do |food| %>
          <%= render "food_card", id: food.id %>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
